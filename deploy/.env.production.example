DJANGO_SECRET_KEY=replace-with-a-long-random-secret
KUBOARD_ENCRYPTION_KEY=replace-with-a-32-byte-secret
DJANGO_ALLOWED_HOSTS=kuboard.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://kuboard.example.com
CORS_ALLOWED_ORIGINS=https://kuboard.example.com
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
DJANGO_SECURE_HSTS_SECONDS=31536000
REDIS_URL=redis://redis:6379/1
REDIS_PASSWORD=
KUBOARD_WEB_PORT=8080
KUBOARD_BOOTSTRAP_ADMIN=true
KUBOARD_ADMIN_EMAIL=admin@example.com
KUBOARD_ADMIN_PASSWORD=replace-with-a-strong-password
KUBOARD_ADMIN_DISPLAY_NAME=Kuboard Admin
UVICORN_WORKERS=1
CELERY_CONCURRENCY=1
