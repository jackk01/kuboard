DJANGO_DEBUG=true
DJANGO_LOG_LEVEL=INFO
KUBOARD_STARTUP_LOG_LEVEL=INFO
DJANGO_SECRET_KEY=kuboard-dev-secret-key-change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
DJANGO_TIME_ZONE=Asia/Shanghai
SQLITE_PATH=/absolute/path/to/backend/db.sqlite3
SQLITE_TIMEOUT_SECONDS=20
REDIS_URL=redis://127.0.0.1:6379/1
REDIS_PASSWORD=
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
KUBOARD_ENCRYPTION_KEY=replace-with-your-own-secret
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_USE_X_FORWARDED_HOST=false
DJANGO_TRUST_X_FORWARDED_PROTO=false
DJANGO_STATIC_ROOT=/absolute/path/to/backend/staticfiles
